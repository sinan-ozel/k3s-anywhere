# GitHub personal access token.
# Required scopes: repo (read) + actions (read).
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Repository where the cluster workflow runs (owner/repo).
# For same-repo use: your-org/k3s-anywhere
# For cross-repo use: your-org/your-app
GITHUB_REPO=your-org/your-app

# Cluster name — must match CLUSTER_NAME in your cluster config file.
CLUSTER_NAME=my-cluster

# age private key for decryption (the AGE-SECRET-KEY-1... line from age-keygen).
# Leave blank only if the artifact was uploaded without sops_age_recipient.
SOPS_AGE_KEY=AGE-SECRET-KEY-1...
