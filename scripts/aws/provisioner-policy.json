{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "StateBucket",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": [
        "arn:aws:s3:::{{BUCKET}}",
        "arn:aws:s3:::{{BUCKET}}/*"
      ]
    },
    {
      "Sid": "ClusterBackupBuckets",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": [
        "arn:aws:s3:::*-backups",
        "arn:aws:s3:::*-backups/*"
      ]
    },
    {
      "Sid": "EC2",
      "Effect": "Allow",
      "Action": ["ec2:*"],
      "Resource": "*"
    },
    {
      "Sid": "IAMClusterUsers",
      "Effect": "Allow",
      "Action": [
        "iam:CreateUser",
        "iam:DeleteUser",
        "iam:GetUser",
        "iam:TagUser",
        "iam:ListUserTags",
        "iam:PutUserPolicy",
        "iam:GetUserPolicy",
        "iam:DeleteUserPolicy",
        "iam:CreateAccessKey",
        "iam:DeleteAccessKey",
        "iam:ListAccessKeys",
        "iam:ListGroupsForUser"
      ],
      "Resource": [
        "arn:aws:iam::{{ACCOUNT_ID}}:user/*-backup",
        "arn:aws:iam::{{ACCOUNT_ID}}:user/*-externaldns"
      ]
    }
  ]
}
