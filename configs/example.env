CLUSTER_NAME=my-cluster
DEFAULT_NODE_COUNT=1
GPU_NODE_COUNT=0
PORT=8888
STATE_BUCKET_NAME=my-k3s-anywhere-state
# USE_PUBLIC_DNS=true  # AWS only: use the EC2 public DNS name in the kubeconfig instead of the IP
# ELASTIC_IP_COUNT=1  # AWS, Exoscale: allocate a static public IP for the control-plane node (alias: ELASTIC_IP)
# EXTERNAL_DNS=true              # enable external-dns support (AWS: provisions dedicated IAM user)
# HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ  # AWS: scope external-dns policy to a single Route 53 zone
